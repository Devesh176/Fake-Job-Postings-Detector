name: fake-job-detector-exp

python_env: python_env.yaml

entry_points:
  train:
    parameters:
      n_estimators:  {type: int,   default: 200}
      max_depth:     {type: int,   default: 5}
      learning_rate: {type: float, default: 0.1}
      subsample:     {type: float, default: 0.8}
    command: "python3 src/model/train.py --n_estimators {n_estimators} --max_depth {max_depth} --learning_rate {learning_rate} --subsample {subsample} --use-mlflow"

  evaluate:
    command: "python3 src/model/evaluate.py"

  register:
    command: "python3 src/model/register.py"